# Copy to .env and fill in values before running

# Hyperliquid wallet private key (hex, with 0x prefix)
HL_PRIVATE_KEY=0x...

# Use testnet for initial PoC (set to "false" for mainnet)
HL_TESTNET=true

# Telegram bot token and chat ID for alerts
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# SQLite database path
DB_PATH=./database/carry.db

# Override capital allocation (optional, defaults match constants.py)
# ACTIVE_CAPITAL_USD=1050.0
# POSITION_SIZE_USD=300.0
# MAX_POSITIONS=3

# ── Cross-venue (HL + Lighter) arbitrage — required for main_cross.py ─────────
# Your Ethereum address registered on Lighter (same wallet as HL)
LIGHTER_L1_ADDRESS=0x...

# Lighter account index — visible in lighter.xyz → Account Settings (top right)
LIGHTER_ACCOUNT_INDEX=

# API key slot to use (0 and 1 are reserved for web/mobile; start with 2)
LIGHTER_API_KEY_INDEX=2

# API key private key — generate at lighter.xyz → Settings → API Keys → Create
# This is NOT your Ethereum private key. It is a Lighter-specific signing key.
LIGHTER_API_PRIVATE_KEY=

# Install Lighter SDK before running main_cross.py:
#   uv pip install git+https://github.com/elliottech/zklighter-perps-python.git

# ── Optional: HL WebSocket (set false if blocked, e.g. by ISP/firewall) ──────
# When disabled, funding payments not tracked in real-time, but bot trades fine.
HL_WS_ENABLED=true

# ── Optional: Telegram proxy (if api.telegram.org blocked, e.g. in Russia) ───
# Examples: socks5://127.0.0.1:1080  or  http://127.0.0.1:8080
# TELEGRAM_PROXY=
